{
  "$schema": "https://raw.githubusercontent.com/shellicar/claude-cli/main/schema/sdk-config.schema.json",
  "model": "claude-opus-4-8",
  "maxTokens": 120000,
  "thinking": {
    "enabled": true,
    "effort": "low"
  },
  "historyReplay": {
    "enabled": true,
    "showThinking": false
  },
  "claudeMd": {
    "enabled": true,
    "sources": {
      "user": true,
      "project": true,
      "projectClaude": true,
      "local": true
    }
  },
  "systemPrompt": {
    "enabled": true,
    "sources": {
      "user": true,
      "project": true,
      "projectClaude": true,
      "local": true
    },
    "text": null
  },
  "compact": {
    "enabled": false,
    "inputTokens": 160000,
    "pauseAfterCompaction": true,
    "customInstructions": null
  },
  "advancedTools": {
    "enabled": false,
    "searchTool": null,
    "allowProgrammaticExecution": [],
    "codeExecutionTool": "code_execution_20260120"
  },
  "serverTools": {
    "webSearch": {
      "enabled": false,
      "version": "web_search_20260209",
      "allowedCallers": [
        "direct"
      ]
    },
    "webFetch": {
      "enabled": false,
      "version": "web_fetch_20260209",
      "allowedCallers": [
        "direct"
      ]
    }
  },
  "hooks": {
    "approvalNotify": {
      "command": "./hooks/approval_notify.sh",
      "delayMs": 5000
    }
  },
  "tools": {
    "exec": true,
    "execV2": true
  },
  "statusBar": {
    "showConversationId": true
  },
  "permissions": {
    "default": {
      "read": "approve",
      "write": "approve",
      "delete": "ask"
    },
    "outside": {
      "read": "approve",
      "write": "approve",
      "delete": "deny"
    }
  }
}
